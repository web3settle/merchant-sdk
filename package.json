{
  "name": "@web3settle/merchant-sdk",
  "version": "0.2.0",
  "description": "React SDK for accepting crypto payments via Web3Settle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "audit:ci": "npm audit --audit-level=high",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@wagmi/core": "^2.16.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.0",
    "@wagmi/core": "^2.16.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "viem": "^2.21.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.2.0",
    "wagmi": "^2.14.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "hono": "^4.12.14",
    "lodash": "^4.18.1",
    "follow-redirects": "^1.16.0",
    "esbuild": "^0.25.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web3settle/merchant-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/web3settle/merchant-sdk/issues"
  },
  "homepage": "https://github.com/web3settle/merchant-sdk#readme",
  "keywords": [
    "web3",
    "crypto",
    "payments",
    "react",
    "sdk",
    "blockchain",
    "ethereum",
    "polygon",
    "base",
    "wagmi",
    "viem"
  ]
}
